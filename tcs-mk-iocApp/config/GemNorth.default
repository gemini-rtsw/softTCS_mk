group {
 double $(top)im:aVals:Z18 = 0.02 ;
 double $(top)im:bVals:Z18 = 0.0 ;
 double $(top)im:cVals:Z18 = -0.1 ;
}
group {
 double $(top)im:aVals:Z19 = -0.27 ;
 double $(top)im:bVals:Z19 = 0.0 ;
 double $(top)im:cVals:Z19 = -0.03 ;
}
string $(top)im:m1TriggerLoadModel = "enabled" ; # Make sure model is loaded

# Set some default values for M1 Figure corrections that are currently blank after a reboot.

double $(top)m1Figure.A = 0.0;
double $(top)m1Figure.B = 0.0;
double $(top)m1Figure.C = 0.0;
double $(top)m1Figure.D = 0.0;
double $(top)m1Figure.E = 0.0;
double $(top)m1Figure.F = 0.0;
double $(top)m1Figure.G = 0.0;
double $(top)m1Figure.H = 0.0;
double $(top)m1Figure.I = 0.0;
double $(top)m1Figure.J = 0.0;
double $(top)m1Figure.K = 0.0;
double $(top)m1Figure.L = 0.0;
double $(top)m1Figure.M = 0.0;
double $(top)m1Figure.N = 0.0;

#
#  Parameters controlling guide filtering.
#
double $(top)ak:guide:scanrate = 0.05;       # Scan rate 20 Hz
double $(top)ak:guide:bw = 0.1;              # Filter bandwidth
double $(top)ak:guide:scale = 3.86956518;    # Scale factor (arcsec on the sky
                                             # to M2 ti/p/tilt)
double $(top)ak:guide:agbw = 1.0;            # A & G Filter bandwidth
double $(top)ak:guide:agscale = 0.620561515; # Scale factor (arcsec on the sky
                                             # to mm on wave front sensor)
double $(top)ak:wfsguide:scanrate = 0.05;    # Scan rate 20 Hz
double $(top)ak:wfsguide:bw = 0.5;           # A & G to WFS Filter bandwidth
double $(top)ak:wfsguide:oiZ1scale = 70.0;   # Probe guide scale factor
double $(top)ak:wfsguide:oiZ2scale = 70.0;   # Probe guide scale factor

double $(top)rotatorGuideGain = 1.0 ;        # Not used by Gemini North
#
# Default TCS  parameters
#
double $(top)display:tzone = -10.0;     # Hours west of Greenwich
string $(top)display:tzonestr = "HST";  # Hawaii Standard Time
string $(top)name = "Gemini-North";     # System name as per ICD2
#
# Default parameters for follow command
#
group {
 string $(top)mcFollow.A = "Off" ;      # Mount following Off
 string $(top)crFollow.A = "Off" ;      # Rotator following Off
 string $(top)pwfs1Follow.A = "Off" ;   # PWFS1 following Off
 string $(top)pwfs2Follow.A = "Off" ;   # PWFS2 following Off
 string $(top)oiwfsFollow.A = "Off" ;   # OIWFS following Off
 string $(top)aoFollow.A = "Off" ;      # AO following Off
 string $(top)m2Follow.A = "Off";       # M2 following off
}
group {
string $(top)mcFollow.DIR = "CLEAR" ;   # Other wise command is marked
string $(top)m2Follow.DIR = "CLEAR" ;   # Other wise command is marked
string $(top)crFollow.DIR = "CLEAR" ;   # Other wise command is marked
string $(top)aoFollow.DIR = "CLEAR" ;   # Other wise command is marked
string $(top)pwfs1Follow.DIR = "CLEAR"; # Other wise command is marked
string $(top)pwfs2Follow.DIR = "CLEAR"; # Other wise command is marked
string $(top)oiwfsFollow.DIR = "CLEAR"; # Other wise command is marked
}
#
# Default values for load command
#
string $(top)load.A = "0" ;          # Apply to CURRENT TCB
string $(top)load.DIR = "CLEAR" ;    # Otherwise load is marked
#
# Default values for save command
#
string $(top)save.A = "0" ;          # Apply to CURRENT TCB
string $(top)save.DIR = "CLEAR" ;    # Otherwise save is marked
#
# Default values for azwrap command
#
string $(top)azwrap.A = "0" ;          # Wrap zero 
string $(top)azwrap.DIR = "CLEAR" ;    # Otherwise azwrap is marked
#
# Default values for telstop command
#
group {
 string $(top)telstop.A = "BOTH" ;     # Stop both axes
 string $(top)telstop.B = "YES"  ;     # Apply az brakes when stopped
 string $(top)telstop.C = "YES"  ;     # Apply el brakes when stopped
}
string $(top)telstop.DIR = "CLEAR" ;   # Otherwise telstop is marked
#
# Default values for rotwrap command
#
string $(top)rotwrap.A = "0" ;          # Wrap zero
string $(top)rotwrap.DIR = "CLEAR" ;    # Otherwise rotwrap is marked
#
# Default values for tcbdefn command
#
string $(top)tcbdefn.A = "Current" ;    # Default is Current TCB
string $(top)tcbdefn.DIR = "CLEAR" ;    # Otherwise command is marked
#
# Default input for the chop command
#
string $(top)chop.A = "Off" ;           # No chopping
string $(top)chop.B = "On" ;            # DECS is enabled
string $(top)chop.C = "Off" ;           # DECS freeze is off
string $(top)chop.D = "Off" ;           # DECS pause is disabled
string $(top)chop.E = "Off" ;           # DECS reset is disabled
string $(top)chop.DIR = "CLEAR" ;       # Otherwise command is marked
#
# Default input for chopConfig command
#
string $(top)chopConfig.A = "none" ;    # Type of chopping 
string $(top)chopConfig.B = "SCS" ;     # Sync source is SCS
string $(top)chopConfig.D = "80.0";     # chop duty cycle (percentage)
string $(top)chopConfig.DIR = "CLEAR";  # Otherwise command is marked
#
# Default input for datum command. This is used to send to the MCS and is
# necessary because the datum command is specified to have no parameters
# whereas the mount datum command needs them.
#
group {
 string $(top)datum.B = "BOTH" ;        # Datum both az and el
 string $(top)datum.C = "SWITCH" ;      # Use switch on az axis
 string $(top)datum.D = "SWITCH" ;      # use switch on el axis
} 
string $(top)datum.DIR = "CLEAR" ;      # Otherwise command is marked
group {
 string $(top)mountDatum.A = "BOTH" ;   # Datum both az and el
 string $(top)mountDatum.B = "SWITCH" ; # Use switch on az axis
 string $(top)mountDatum.C = "SWITCH" ; # use switch on el axis
} 
string $(top)mountDatum.DIR = "CLEAR" ; # Otherwise command is marked
#
# Default input for the debug command
# Note that debugString is caused to process to ensure that all status
# records have the correct initial value. debugString fetches its input
# from debug.VALA which is why that field is set.
#
string $(top)debug.VALA = "NONE" ;      # Must be same as TCS debug state
string $(top)debugString.PROC = "1";    # Any value will do
string $(top)debug.A = "None" ;         # TCS debug state
string $(top)debug.B = "None" ;         # MCS debug state
string $(top)debug.C = "None" ;         # CRS debug state
string $(top)debug.D = "None" ;         # ECS debug state
string $(top)debug.E = "None" ;         # A&G debug state
string $(top)debug.F = "None" ;         # M2 debug state
string $(top)debug.G = "None" ;         # PCS debug state
string $(top)debug.H = "None" ;         # AO debug state
string $(top)debug.DIR = "CLEAR";       # Otherwise command is marked
#
# Default input for the carouselMode command
#
string $(top)sad:carouselDriveMode = "Basic" ;   # Make sure SAD is initialized
string $(top)sad:shutterDriveMode = "Fully Open";
string $(top)carouselMode.A = "Basic" ;  # Simplest tracking mode
string $(top)carouselMode.B = "FullyOpen" ; 
string $(top)carouselMode.C = "9320.0" ; # Set to minimum slit height
string $(top)carouselMode.D = "Off" ;    # Don't automatically start Dome
string $(top)carouselMode.E = "Off" ;    # Don't automatically open shutters
string $(top)carouselMode.DIR = "CLEAR"; # Otherwise command is marked
#
# Default input for the pwfs1Observe command
#
string $(top)pwfs1Observe.A = "-1" ;     # Measure tip/tilt and focus
string $(top)pwfs1Observe.DIR = "CLEAR"; # Otherwise command is marked
#
# Default input for other pwfs1 commands
string $(top)p1detSigInit.A = "data/defFullP1DarkMK.fits" ; # Dark file name
string $(top)p1detSigInit.DIR = "CLEAR"; # Otherwise command is marked
#
string $(top)p1SeqDark.A = "coadd.fits" ; # Dark file name
string $(top)p1SeqDark.DIR = "CLEAR" ;    # Otherwise comamnd is marked
#
string $(top)p1Seq.A = "1.0" ;            # Global integration period (secs)
string $(top)p1Seq.B = "30.0" ;           # Frame averaging for aO (secs)
string $(top)p1Seq.C = "1" ;              # Flag for writing Z to SCS
string $(top)p1Seq.D = "3.5" ;            # Rms multiplier for image
string $(top)p1Seq.DIR = "CLEAR" ;        # Otherwise command is marked
#
# Default input for the pwfs2Observe command
#
string $(top)pwfs2Observe.A = "-1" ;     # Measure tip/tilt and focus
string $(top)pwfs2Observe.DIR = "CLEAR"; # Otherwise command is marked
#
# Default input for other pwfs2 commands
string $(top)p2detSigInit.A = "data/defBinP2DarkMK.fits" ; # Dark file name
string $(top)p2detSigInit.DIR = "CLEAR"; # Otherwise command is marked
#
string $(top)p2SeqDark.A = "coadd.fits" ; # Dark file name
string $(top)p2SeqDark.DIR = "CLEAR" ;    # Otherwise comamnd is marked
#
string $(top)p2Seq.A = "1.0" ;            # Global integration period (secs)
string $(top)p2Seq.B = "30.0" ;           # Frame averaging for aO (secs)
string $(top)p2Seq.C = "1" ;              # Flag for writing Z to SCS
string $(top)p2Seq.D = "3.5" ;            # Rms multiplier for image
string $(top)p2Seq.DIR = "CLEAR" ;        # Otherwise command is marked
#
# Default input for the oiwfsObserve command
#
string $(top)oiwfsObserve.A = "-1" ;     # Measure tip/tilt and focus
string $(top)oiwfsObserve.DIR = "CLEAR"; # Otherwise command is marked
#
# Default input for other oiwfs commands
#
string $(top)oiSigInit.A = "data/defBinOiwfsDarkMK.fits" ; # Dark file name
string $(top)oiSigInit.DIR = "CLEAR"; # Otherwise command is marked
#
string $(top)oiSeqDark.A = "coadd.fits" ; # Dark file name
string $(top)oiSeqDark.DIR = "CLEAR" ;    # Otherwise comamnd is marked
#
string $(top)oiSeq.A = "1.0" ;            # Global integration period (secs)
string $(top)oiSeq.B = "30.0" ;           # Frame averaging for aO (secs)
string $(top)oiSeq.C = "1" ;              # Flag for writing Z to SCS
string $(top)oiSeq.D = "3.5" ;            # Rms multiplier for image
string $(top)oiSeq.DIR = "CLEAR" ;        # Otherwise command is marked
#
# Default input for the m2GuideControl command
#
string $(top)m2GuideControl.A = "On" ;   # Respond to WFS signals 
string $(top)m2GuideControl.B = "Off" ;  # Don't reset 
string $(top)m2GuideControl.DIR = "CLEAR" ; # Otherwise command is marked 
#
# Default data for m1GuideConfig command
group {
string $(top)m1GuideConfig.A = "None";   # Weighting scheme
string $(top)m1GuideConfig.B = "PWFS1";  # Default source of aO data 
string $(top)m1GuideConfig.C = "1";      # Default no. of frames to average 
}
string $(top)m1GuideConfig.DIR = "CLEAR"; # Otherwise command is left marked
#
# Default for m2GuideConfig - this is temporary until the 3.13 CAD record
# sets nulls rather than " " as the default
string $(top)m2GuideConfig.B = "200" ; # Sample frequency
string $(top)m2GuideConfig.C = "RAW" ; # Filter
string $(top)m2GuideConfig.D = "20"  ; # Chop Freq 1
string $(top)m2GuideConfig.E = "20"  ; # Chop Freq 2
string $(top)m2GuideConfig.F = "A"   ; # Chop Beam
string $(top)m2GuideConfig.G = "OFF" ; # Reset option
string $(top)m2GuideConfig.DIR = "CLEAR" ;
#
# Default PID gains for m2SetController
#
group {
string $(top)m2SetController.A = "0.5";    # P term for X tilt
string $(top)m2SetController.B = "0.4";    # I term for X tilt
string $(top)m2SetController.C = "0.0";    # D term for X tilt
string $(top)m2SetController.D = "0.0596"; # P term for Z focus 
string $(top)m2SetController.E = "0.2086"; # I term for Z focus 
string $(top)m2SetController.F = "0.0";    # D term for Z focus 
string $(top)m2SetController.G = "0.5";    # P term for Y tilt
string $(top)m2SetController.H = "0.4";    # I term for Y tilt
string $(top)m2SetController.I = "0.0";    # D term for Y tilt
} ;
string $(top)m2SetController.DIR = "CLEAR" ;
#
# Default for where TCS gets its mount offload signals
#
string $(top)mountGuideMode.B = "SCS" ;  # Source of mount guide signals
string $(top)mountGuideMode.DIR = "CLEAR" ;
#
# Defaults for chopRelative command
string $(top)chopRelative.C  = "FK5" ;   # Chop frame
string $(top)chopRelative.DIR = "CLEAR" ;
#
# Default wavelength for OSCIR
#
string $(top)wavelSourceB.A = "1.0" ;    # 1 micron
string $(top)wavelSourceB.DIR = "CLEAR" ;
#
# Default data for oiwfsSelect command
#
group {
string $(top)oiwfsSelect.A = "None" ;    # Name of WFS to use
string $(top)oiwfsSelect.B = "WFS" ;     # Where to send WFS data
}
string $(top)oiwfsSelect.DIR = "CLEAR" ;
#
# Default values for the GPOL datum and move commands
#
group {
string $(top)gpolPlateMove.A = "Out" ;   # Upper plate out
string $(top)gpolPlateMove.B = "Out" ;   # Middle plate out
string $(top)gpolPlateMove.C = "Out" ;   # Lower plate out
} ;
string $(top)gpolPlateMove.DIR = "CLEAR" ;
group {
string $(top)gpolPlateDatum.A = "No" ;   # Upper plate 
string $(top)gpolPlateDatum.B = "No" ;   # Middle plate 
string $(top)gpolPlateDatum.C = "No" ;   # Lower plate 
} ;
string $(top)gpolPlateDatum.DIR = "CLEAR" ;

#
# Default parameters for the gsaoiodgwSetup command - not really
# needed for Gemini North but it keeps the North and South
# configuration files in line
#
group {
  string $(top)gsaoiodgwSetup.A = "DCS" ;   # Read method
  string $(top)gsaoiodgwSetup.B = "1" ;     # No. of resets
  string $(top)gsaoiodgwSetup.C = "1" ;     # No. of Fowler samples
  string $(top)gsaoiodgwSetup.D = "0.1" ;   # ODGW base exposure time (secs)
  string $(top)gsaoiodgwSetup.E = "1" ;     # No. interleaved science rows 
  string $(top)gsaoiodgwSetup.F = "1" ;     # No. interleaved idle rows
  string $(top)gsaoiodgwSetup.G = "1" ;     # ODGW1 exposure multiplier 
  string $(top)gsaoiodgwSetup.H = "1" ;     # ODGW2 exposure multiplier
  string $(top)gsaoiodgwSetup.I = "1" ;     # ODGW3 exposure multiplier 
  string $(top)gsaoiodgwSetup.J = "1" ;     # ODGW4 exposure multiplier 
  string $(top)gsaoiodgwSetup.L = "NO" ;    # Save copy 
  string $(top)gsaoiodgwSetup.M = "MCAO" ;  # Guider output 
  string $(top)gsaoiodgwSetup.N = "YES" ;   # Display ODGW
  string $(top)gsaoiodgwSetup.O = "10.0" ;  # Display rate (Hz)
}
string $(top)gsaoiodgwSetup.DIR = "CLEAR";

