} ;
string $(top)om:setModel.PROC = "1" ;       # Trigger processing
#
# Data and parameters for M1 open loop figure model
#
int $(top)drives:m1Interval = 30 ;               # Update every 30 seconds
double $(top)drives:m1ModelMaxAge = 1000.0;  # Max age (hrs) for valid file

# updated 12 June 99 following observations by FR
# updated 24 Jan 00  from data of 17/18 Jan
# New terms from Inger Jorgensen 15 Feb DLT
# updated 12 Sep 00 for sin trefoil by SC
# updated 01 Aug 02 for Z8 C coefficient by SC
# New terms from Maxime Boccas 1 Sep 04 MB
# New terms from Maxime Boccas 16 Aug 06 MB
# New terms 03 Jan 2008
# New terms 02Aug 2008  Brian Walls
# New terms TS and TV 07Feb2013 (values from Jan2012)
# New terms TS and TV 27Sep2013 (M1 recoat)
# New terms TS 31Mar2015
# New terms TS 30Nov2015 (Z4 Z5 Z9 Z10 Z11 Z12)
