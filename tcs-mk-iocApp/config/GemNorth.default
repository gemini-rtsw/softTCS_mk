#
# Data for empirical off axis data model
#
group {
 double $(top)om:ast0Zero    = 0.0 ;
 double $(top)om:ast0Scale   = 1.0 ;
 double $(top)om:ast0Phase   = 180.0 ;
 double $(top)om:ast45Zero   = 0.0 ;
