#
#  pvload parameter definition file
#
# Initiate check for Xycom hardware and state of Interlock system
#
string $(top)checkForXycom.PROC = "1"; # Any value to force processing
#
# Set up default values for system statistic scan rates
#
# double $(top)cpuScanPeriod    = 5.0 ;   # Estimate CPU load every 5 secs
# double $(top)memoryScanPeriod = 10.0 ;  # Estimate memory usage every 10 secs
# double $(top)fdScanPeriod     = 10.0 ;  # Estimate FD usage every 10 secs
#
# Default mechanism limits. Processing of the times to limits record
# is disabled here so that it doesn't run before the kernel is 
# generating valid data.
#
int $(top)limits:times.DISA = 1;       # Disable limit calculation
double $(top)rmadef   = 0.0;           # Rotator P.A. (degrees)
double $(top)azdef    = 90.0;          # Default azimuth (degrees)
double $(top)eldef    = 90.0;          # Default elevation (degrees)
double $(top)azveldef = 2.0;           # Default az velocity (deg/s)
double $(top)elveldef = 0.75;          # Default el velocity (deg/s)
double $(top)paveldef = 5.0;           # Default PA velocity (deg/s)
double $(top)ellimit  = 17.0;          # Elevation lower limit (degrees)
double $(top)azlolimit  = -180.0;      # Azimuth lower limit (degrees)
double $(top)azhilimit  = 355.0;       # Azimuth upper limit (degrees)
double $(top)rotlolimit  = -265.0;     # Rotator lower limit (degrees)
double $(top)rothilimit  = 265.0;      # Rotator upper limit (degrees)
double $(top)zlimit = 0.5;             # Zenith avoidance limit (degrees)
double $(top)airmasslimit = 2.0;       # Air mass limit
#
# Default parameters for disabling mount following
#
group {
 string $(top)mcFollow:axes = "BOTH" ;   # Stop following on both axes
 string $(top)mcFollow:azBrake = "NO" ;  # Don't apply azimuth brakes
 string $(top)mcFollow:elBrake = "NO" ;  # Don't apply elevation brakes
}
#
# Default parameter when disabling rotator following
#
string $(top)crFollow:crBrake = "NO" ;    # Don't apply brakes
#
# Default startup parameters for M2. 
#
double $(top)def:m2MinChopFreq = 0.1;   # Min. chop frequency (Hz)
double $(top)def:m2BreakChopFreq = 5.0; # Chop freq. at break
double $(top)def:m2MaxChopFreq = 10.0;  # Max. chop frequency (Hz)
double $(top)def:m2MinChopFreqThrow = 130.0; # Throw at min freq. (arcsec)
double $(top)def:m2BreakChopFreqThrow = 130.0; # Throw at break (arcsec)
double $(top)def:m2MaxChopFreqThrow = 60.0; # Throw at max freq. (arcsec)
double $(top)def:m2MinTilt = 0.0;       # Minimum tilt (arcsec)
double $(top)def:m2MaxTilt = 3600.0;    # Maximum tilt (arcsec)
double $(top)def:m2MinTiltZ = 10.0;     # Max Z at min. tilt (mm)
double $(top)def:m2MaxTiltZ = 5.0;      # Max Z at max. tilt (mm)
string $(top)defTopEnd = "F16";        # Default top end is F/16
#
# Default startup limits for Altair - these are only used if and until
# the Altair system is loaded
#
group {
string $(top)def:aowfsLimitType = "XY";     # Altair is on an XY table
double $(top)def:aowfsRmin = 0.0;           # probe can reach centre
double $(top)def:aowfsRmax = 53.0 ;         # Max. radius (mm)
double $(top)def:aowfsXmin = -37.2 ;        # Minimum X (mm)
double $(top)def:aowfsXmax = 37.2 ;         # maximum X (mm)
double $(top)def:aowfsYmin = -37.2 ;        # Minimum Y (mm)
double $(top)def:aowfsYmax = 37.2 ;         # maximum Y (mm)
double $(top)def:aowfsZmin = -12.0;         # Minimum Z (mm)
double $(top)def:aowfsZmax = 12.0;          # maximum Z (mm)
double $(top)def:aowfsXposn = 35.0;         # Default X posn (mm)
double $(top)def:aowfsYposn = 35.0;         # Default Y posn (mm)
double $(top)def:aowfsZposn = 0.0;          # Default Z posn (mm)
};
#
# Altair probe offsets. The x,y values are equal to the pointing origin
# of Altair when its gimbals re at 0,0
#
double $(top)drives:aoXoffset = 0.74;      # Focus offset of wfs (mm)
double $(top)drives:aoYoffset = -0.37;     # Focus offset of wfs (mm)
double $(top)drives:aoZoffset = 0.0;       # Focus offset of wfs (mm)
#
# Default set up parameters for the AOM (Canopus)
#
# These are used if and only if the AOM can't be contacted at startup.
# Once the AOM is booted the TCS sequence program will use the data read
# back from it.
#
group {
string $(top)def:aomngsPr1LimitType = "Radial"; # Not strictly true
double $(top)def:aomngsPr1Rmin = 0.0;           # probe can reach centre
double $(top)def:aomngsPr1Rmax = 41.0 ;         # Max. radius (mm)
double $(top)def:aomngsPr1Xmin = -41.0 ;        # Minimum X (mm)
double $(top)def:aomngsPr1Xmax = 15.0 ;         # maximum X (mm)
double $(top)def:aomngsPr1Ymin = -41.0 ;        # Minimum Y (mm)
double $(top)def:aomngsPr1Ymax = 41.0 ;         # maximum Y (mm)
double $(top)def:aomngsPr1Xposn = -31.0;         # Default X posn (mm)
double $(top)def:aomngsPr1Yposn = 32.0;         # Default Y posn (mm)
};
group {
string $(top)def:aomngsPr2LimitType = "Radial"; # Not strictly true
double $(top)def:aomngsPr2Rmin = 0.0;           # probe can reach centre
double $(top)def:aomngsPr2Rmax = 41.0 ;         # Max. radius (mm)
double $(top)def:aomngsPr2Xmin = -15.0 ;        # Minimum X (mm)
double $(top)def:aomngsPr2Xmax = 41.0 ;         # maximum X (mm)
double $(top)def:aomngsPr2Ymin = -41.0 ;        # Minimum Y (mm)
double $(top)def:aomngsPr2Ymax = 41.0 ;         # maximum Y (mm)
double $(top)def:aomngsPr2Xposn = 32.0;         # Default X posn (mm)
double $(top)def:aomngsPr2Yposn = 33.0;         # Default Y posn (mm)
};
group {
string $(top)def:aomngsPr3LimitType = "Radial"; # probe 3 has a circular area
double $(top)def:aomngsPr3Rmin = 0.0;           # probe can reach centre
double $(top)def:aomngsPr3Rmax = 41.0 ;         # Max. radius (mm)
double $(top)def:aomngsPr3Xmin = -41.0 ;        # Minimum X (mm)
double $(top)def:aomngsPr3Xmax = 41.0 ;         # maximum X (mm)
double $(top)def:aomngsPr3Ymin = -41.0 ;        # Minimum Y (mm)
double $(top)def:aomngsPr3Ymax = 41.0 ;         # maximum Y (mm)
double $(top)def:aomngsPr3Xposn = 33.0;         # Default X posn (mm)
double $(top)def:aomngsPr3Yposn = 34.0;         # Default Y posn (mm)
};

#
# Default startup parameters for A&G. These are only used when it is not
# possible to connect to the A&G or the TCS's internal simulation of the
# A&G. The defaults are based on a probe arm length of 400mm and max. angles
# of 48 and 43 degs, 2000 and 1615 mm above focal plane respectively.
#
string $(top)def:pwfs1LimitType = "Radial"; # pwfs1 is on a rotary table
double $(top)def:pwfs1Rmin = 0.0;           # probe can reach centre
double $(top)def:pwfs1Rmax = 380.0;         # Max. radius (mm)
double $(top)def:pwfs1Xmin = -380.0;        # Minimum X (mm)
double $(top)def:pwfs1Xmax = 380.0;         # maximum X (mm)
double $(top)def:pwfs1Ymin = -380.0;        # Minimum Y (mm)
double $(top)def:pwfs1Ymax = 380.0;         # maximum Y (mm)
double $(top)def:pwfs1Zmin = -0.2;         # Minimum Z (mm)
double $(top)def:pwfs1Zmax = 29.0;          # maximum Z (mm)
double $(top)def:pwfs1Xposn = 300.0;        # Default X posn (mm)
double $(top)def:pwfs1Yposn = 0.0;          # Default Y posn (mm)
double $(top)def:pwfs1Zposn = 0.0;          # Default Z posn (mm)
double $(top)def:pwfs1RTmin = -200.0;       # Min. rotary table angle (degs)
double $(top)def:pwfs1RTmax = 200.0;        # Max. rotary table angle (degs)
string $(top)def:pwfs2LimitType = "Radial"; # pwfs2 is on a rotary table
double $(top)def:pwfs2Rmin = 0.0;           # probe can reach centre
double $(top)def:pwfs2Rmax = 325.0;         # Max. radius (mm)
double $(top)def:pwfs2Xmin = -325.0;        # Minimum X (mm)
double $(top)def:pwfs2Xmax = 325.0;         # maximum X (mm)
double $(top)def:pwfs2Ymin = -325.0;        # Minimum Y (mm)
double $(top)def:pwfs2Ymax = 325.0;         # maximum Y (mm)
double $(top)def:pwfs2Zmin = -11.3;         # Minimum Z (mm)
double $(top)def:pwfs2Zmax = 18.8;          # maximum Z (mm)
double $(top)def:pwfs2Xposn = 300.0;        # Default X posn (mm)
double $(top)def:pwfs2Yposn = 0.0;          # Default Y posn (mm)
double $(top)def:pwfs2Zposn = 0.0;          # Default Z posn (mm)
double $(top)def:pwfs2RTmin = -200.0;       # Min. rotary table angle (degs)
double $(top)def:pwfs2RTmax = 200.0;        # Max. rotary table angle (degs)
string $(top)def:oiwfsLimitType = "XY";     # oiwfs is on an XY table
double $(top)def:oiwfsRmin = 0.0;           # probe can reach centre
double $(top)def:oiwfsRmax = 150.0;         # Max. radius (mm)
double $(top)def:oiwfsXmin = -150.0;        # Minimum X (mm)
double $(top)def:oiwfsXmax = 150.0;         # maximum X (mm)
double $(top)def:oiwfsYmin = -150.0;        # Minimum Y (mm)
double $(top)def:oiwfsYmax = 150.0;         # maximum Y (mm)
double $(top)def:oiwfsZmin = -12.0;         # Minimum Z (mm)
double $(top)def:oiwfsZmax = 12.0;          # maximum Z (mm)
double $(top)def:oiwfsXposn = 150.0;        # Default X posn (mm)
double $(top)def:oiwfsYposn = 0.0;          # Default Y posn (mm)
double $(top)def:oiwfsZposn = 0.0;          # Default Z posn (mm)
double $(top)drives:pwfs1XNominal = 0.0;    # Nominal X position
double $(top)drives:pwfs1YNominal = 0.0;    # Nominal Y position
double $(top)drives:pwfs1ZNominal = 0.0;    # Nominal Z position
double $(top)drives:pwfs2XNominal = 0.0;    # Nominal X position
double $(top)drives:pwfs2YNominal = 0.0;    # Nominal Y position
double $(top)drives:pwfs2ZNominal = 0.0;    # Nominal Z position
double $(top)drives:oiwfsXNominal = 0.0;    # Nominal X position
double $(top)drives:oiwfsYNominal = 0.0;    # Nominal Y position
double $(top)drives:oiwfsZNominal = 0.0;    # Nominal Z position
#
# Default user limits. Writing to these cause the corresponding
# SAD items to be updated. These values will later be overwritten by
# tcsSeqInit with data from the A&G
#
group {
 double $(top)pwfs1Rmin = 0.0;       # Min radius for PWFS1 (mm)
 double $(top)pwfs1Rmax = 380.0;     # Max radius for PWFS1 (mm) 
 double $(top)pwfs2Rmin = 0.0;       # Min radius for PWFS2 (mm)
 double $(top)pwfs2Rmax = 325.0;     # Max radius for PWFS2 (mm) 
}
#
# Default startup parameters for the ECS. These are only used if it is
# not possible to connect to the ECS on startup
#
double $(top)def:minBotShtr = 0.5;     # Min. elevation bottom shutter (degs)
double $(top)def:maxBotShtr = 63.7;    # Max. elevation bottom shutter (degs)
double $(top)def:minTopShtr = 10.6;    # Min. elevation top shutter (degs)
double $(top)def:maxTopShtr = 105.0;   # Max. elevation top shutter (degs)
double $(top)def:domePos = 90.0;       # Default dome azimuth (degs)
double $(top)def:topShtrPos = 15.0;    # Default top shutter elevation (degs)
double $(top)def:botShtrPos = 15.0;    # Default bottom shutter posn (degs)
double $(top)drives:moveTol = 1.0 ;    # Tolerance for move commands (degs)
#
# Parameters to control ECS positioning
#
double $(top)def:encRadius = 17000.0;  # Enclosure radius (mm)
double $(top)def:slitWidth = 9320.0;   # Slit width (mm)
double $(top)def:beamDiameter = 7909.0; # Beam diameter at M1 (mm)
double $(top)def:minScatWidth = 500.0; # Adjustment for min scatter mode (mm)
double $(top)def:minSlitHeight = 9320.0; # Min. slit height (mm)
double $(top)def:fieldRadius = 8.0 ;   # Field radius (arcmin)
#
# Fixed parameters (TCS/PTW/4.4)
#
# Latitude and longitude changed on 15/5/99 from -155 28 18, 19 49 36
# Height above sea level changed on 17/5/99 from 4145.0
double $(top)ak:del   =  0.0025;       # Probe vector length (rads)
double $(top)ak:tlongm = -155.46906;   # Longitude (-155 28 08.6 in degrees)
double $(top)ak:tlatm  = 19.823806;    # Latitude  (19 49 25.7 in degrees)
double $(top)ak:height = 4213.4;       # Height above sea-level (metres)
double $(top)sodium    = 90.0;         # Default Na layer height (km)
#
# Quasi-fixed parameters (TCS/PTW/4.4)
#
# 2/12/13 Removed Leap sec temporarility D. Coulson
# 2/13/14 Put leap sec back. D. Coulson
#
#
double $(top)ak:delut = 0.0;           # UT1 - UTC (seconds) 
double $(top)ak:delat = 37.0;          # TAI - UTC (seconds)
double $(top)ak:ttmtai = 32.184;       # TT - TAI (seconds)
double $(top)ak:xpm    = 0.0;          # X polar motion (arcsec) 
double $(top)ak:ypm   = 0.0;           # Y polar motion (arcsec) 
double $(top)ak:slow.A = 278.16;       # Initial air temperature (deg K)
double $(top)ak:slow.B = 615.0;        # Initial pressure (mbars)
double $(top)ak:slow.C =  0.2;         # Initial relative humidity
double $(top)ak:tempMax = 50.0;        # Max air temperature (deg C)
double $(top)ak:tempMin = -40.0;       # Min air temparature (deg C)
double $(top)ak:tempDefault =  5.0;    # Default temperature
double $(top)ak:pressMax = 1100.0;     # Max air pressure (millibars)
double $(top)ak:pressMin = 300.0;      # Min air pressure (millibars)
double $(top)ak:pressDefault =  615.0; # Default air pressure (millibars)
double $(top)ak:humidMax = 100.0;      # Max relative humidity (% RH)
double $(top)ak:humidMin = 0.0;        # Min  relative humidity (% RH)
double $(top)ak:humidDefault =  20.0;  # Default relative humidity (% RH)
double $(top)ak:tlr   =  0.0065;       # Tropospheric lapse rate (deg K / m)
double $(top)ak:wavel =  0.5;          # Default wavelength (microns)
double $(top)ak:djmls = 99999.0;      # MJD of next leap second
double $(top)ak:biass = 0.0;           # Time offset for testing (seconds)

double $(top)ak:xim   =  0.0;          # X pointing origin (mm)
double $(top)ak:yim   =  0.0;          # Y pointing origin (mm)
#
# Parameters of M2 optics model 
#
# The theoretical ZThermal coeff is 0.138
# m2ZModelCoeff & m2ZNominal determined from 4 points on 20/5/99
# m2XTiltNominal & m2XTiltModelCoeff determined from 3 points 22/5/99
# Updated 12 June by FR
# Focus elevation term fitted from data of Jan 31 - Feb 1 CJM
# New terms from Inger Jorgensen 15 Feb DLT
# Updated 01-September-2000 by DMW
# m2XNominal, m2YNominal, m2XTiltNominal, m2YTiltNominal changed by SC 6/19/01
# m2ZNominalchanged to 0.450 DMW 2/5/2003
# m2XNominal, m2YNominal, im:cVals:Z4, im:cVals:Z5, im:cVals:Z8, im:cVals:Z12,im:cVals:Z13,im:cVals:Z14, im:cVals:Z17  MBEC 1/22/04
# m2XNominal, m2YNominal, SCHAN 08/11/06
# New terms from TV 03Jan2008, GT (Coma x, y and z.)
# New terms from TV 02Aug2008, BW (Coma x, and y)
# New terms from TS and TV 07Feb2013 (data from Jan2012)
# New terms from TS 31Mar2015 (Coma x and y)
# New terms from TS 30Nov2015 (Coma x and y tilt x and y)
# m2YModelCoeff1 changed from 0.02 to 0.20 and m2XModelCoeff1 changed from -0.09 to -0.90 TS 11Feb2016 (Coma y)
# New terms from TS 30Aug2016 (Coma x and y)
# New terms from TS 13Oct2016 (Coma x and y)
# New terms from TS 22Mar2017 (Coma x and y)
# New terms from TS 26Aug2017 (Coma x and y)
# New terms from TS 08Nov2017 (Coma x and y)
#
group {
 double $(top)om:m2XNominal = 2.31; # X reference position
 double $(top)om:m2YNominal = 2.36; # Y reference position
 double $(top)om:m2ZNominal = -0.25;     # Z reference position
 double $(top)om:m2XYRefTemp = 5.0;     # Reference for thermal model (deg C)
 double $(top)om:m2ZRefTemp  = 0.15;     # Reference for thermal model (deg C)
 double $(top)om:m2TiltRefTemp = 5.0;   # Reference for thermal model (deg C)
 double $(top)om:m2XThermalCoeff = 0.0; # Thermal X coefficient (mm/deg C)
 double $(top)om:m2YThermalCoeff = 0.0; # Thermal Y coefficient (mm/deg C)
 double $(top)om:m2ZThermalCoeff = 0.15; # Thermal Z coefficient (mm/deg C)
 double $(top)om:tt:step1 = 0.5;         # permitted sample step (deg C)
 double $(top)om:tt:step2 = 0.5;         # permitted sample step (deg C)
 double $(top)om:tt:diff  = 1.0;         # permitted sensor difference (deg C)
 double $(top)om:m2XModelCoeff1   = 0.20; # Model X coefficient (mm)
 double $(top)om:m2YModelCoeff1   = -0.24; # Model Y coefficient (mm)
 double $(top)om:m2XModelCoeff2   = 0.0; # Model X coefficient (mm)
 double $(top)om:m2YModelCoeff2   = 0.0; # Model Y coefficient (mm)
 double $(top)om:m2ZModelCoeff1  = 0.496; # Model Z coefficient (mm)
 double $(top)om:m2ZModelCoeff2  = -0.225; # Model Z coefficient (mm)
 
 double $(top)om:m2XTiltNominal  = -224; # Reference for xtilt (arcsec)
 double $(top)om:m2YTiltNominal  = -322; # Reference for ytilt (arcsec)
 double $(top)om:m2XTiltModelCoeff = 0.0 ; # Model Xtilt coeff (arcsec)
 double $(top)om:m2YTiltModelCoeff = 0.0 ; # Model Ytilt coeff (arcsec)
};
#
# Data for M2 tilt correction model
#
int $(top)drives:m2ComaInt = 10;        # update interval for model (secs) 
group {
 string $(top)m2ComaModel.A = "0.0";   # A coefficient 
