# Limits that control when the TCS considers M1 to be settled after a move.
# The numbers are the number of moving actuators. This is used when 
# averaging P1 data
#
group {
int $(top)drives:m1HighLimit   = 15 ;    # High bound of deadband 
int $(top)drives:m1CentreLimit = 10 ;    # Boundary for moving/not moving
int $(top)drives:m1LowLimit    = 5  ;    # Lower bound of deadband 
}
#
# Default values for subsystem CAD messages
#
string $(top)aoSubcadMess = " " ;       # Blank string
string $(top)crSubcadMess = " " ;       # Blank string
string $(top)ecSubcadMess = " " ;       # Blank string
string $(top)m1SubcadMess = " " ;       # Blank string
string $(top)m2SubcadMess = " " ;       # Blank string
string $(top)mcSubcadMess = " " ;       # Blank string
string $(top)agSubcadMess = " " ;       # Blank string
string $(top)wsSubcadMess = " " ;       # Blank string
#
# Default values for tracking frame and equinox SAD records
#
string $(top)sad:sourceATrackFrame = "FK5";
string $(top)sad:sourceBTrackFrame = "FK5";
string $(top)sad:sourceCTrackFrame = "FK5";
string $(top)sad:mountTrackFrame = "FK5";
string $(top)sad:pwfs1TrackFrame = "FK5";
string $(top)sad:pwfs2TrackFrame = "FK5";
string $(top)sad:oiwfsTrackFrame = "FK5";
string $(top)sad:rotTrackFrame = "FK5";
string $(top)sad:sourceATrackEq = "J2000";
string $(top)sad:sourceBTrackEq = "J2000";
string $(top)sad:sourceCTrackEq = "J2000";
string $(top)sad:mountTrackEq = "J2000";
string $(top)sad:pwfs1TrackEq = "J2000";
string $(top)sad:pwfs2TrackEq = "J2000";
string $(top)sad:oiwfsTrackEq = "J2000";
string $(top)sad:rotTrackEqnx = "J2000";
double $(top)sad:sourceAWavelength = 5000;
double $(top)sad:sourceBWavelength = 5000;
double $(top)sad:sourceCWavelength = 5000;
double $(top)sad:mountWavelength = 5000;
double $(top)sad:pwfs1Wavelength = 5000;
double $(top)sad:pwfs2Wavelength = 5000;
double $(top)sad:oiwfsWavelength = 5000;
#
# Set input frames, equinoxs and object names.
#
string $(top)sad:sourceAInputFrame = "FK5";
string $(top)sad:sourceBInputFrame = "FK5";
string $(top)sad:sourceCInputFrame = "FK5";
string $(top)sad:mountInputFrame = "FK5";
string $(top)sad:pwfs1InputFrame = "FK5";
string $(top)sad:pwfs2InputFrame = "FK5";
string $(top)sad:oiwfsInputFrame = "FK5";
string $(top)sad:sourceAEquinox = "J2000.0";
string $(top)sad:sourceBEquinox = "J2000.0";
string $(top)sad:sourceCEquinox = "J2000.0";
string $(top)sad:mountEquinox = "J2000.0";
string $(top)sad:pwfs1Equinox = "J2000.0";
string $(top)sad:pwfs2Equinox = "J2000.0";
string $(top)sad:oiwfsEquinox = "J2000.0";
string $(top)sad:sourceAObjectName = "None set";
string $(top)sad:sourceBObjectName = "None set";
string $(top)sad:sourceCObjectName = "None set";
string $(top)sad:mountObjectName = "None set";
string $(top)sad:pwfs1ObjectName = "None set";
string $(top)sad:pwfs2ObjectName = "None set";
string $(top)sad:oiwfsObjectName = "None set";
#
# Set "defaults" for Epoch. Note, these are not real defaults but simply
# strings so that the SAD records won't be blank on startup. Once
# a target is specified, a proper default will be provided by the TCS
# if a value isn't supplied by the user
#
string $(top)sad:sourceAEpoch = "J2000.0";
string $(top)sad:sourceBEpoch = "J2000.0";
string $(top)sad:sourceCEpoch = "J2000.0";
string $(top)sad:mountEpoch = "J2000.0";
string $(top)sad:pwfs1Epoch = "J2000.0";
string $(top)sad:pwfs2Epoch = "J2000.0";
string $(top)sad:oiwfsEpoch = "J2000.0";
#
# Make sure the program identifier isn't blank on startup
#
string $(top)sad:programID = "None";
#
# Default values for m1ModelRestore command 
