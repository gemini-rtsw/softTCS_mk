$(LINUX_ONLY)#!${INSTALL}/bin/${ARCH}/tcs-mk-ioc

cd ${TEST_INSTALL}
epicsEnvSet("EPICS_CA_ADDR_LIST","10.1.2.255")

substitute "IOCPROMPT=$(SIMTOP)-sim-ioc"
substitute "SUBS=sim.subs"
substitute "TCSTOP=$(SIMTOP),TCSPV=$(SIMTCSPV),TCSSEQ=$(SIMTCSSEQ)"

epicsEnvSet("SIMTOP","$(SIMTOP)")
include "../common.src"
